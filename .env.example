# Copy to .env before first run:  cp .env.example .env

# ---- Database (local container only) ------------------------------------
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=wp_pass

# ---- Ports published on your host ---------------------------------------
# The site's canonical URL is https://newsite.com, so the stack uses the
# standard web ports. If 80/443 are already in use on your machine, stop the
# other web server first (recommended) so the site works without a port in the
# URL.
HTTP_PORT=80
HTTPS_PORT=443
