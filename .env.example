# Copy to .env before first run:  cp .env.example .env

# ---- Database (local container only) ------------------------------------
MYSQL_ROOT_PASSWORD=root_pass
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=wp_pass

# ---- Ports published on your host ---------------------------------------
# The site's canonical URL is https://newsite.com:8443, so keep these unless
# the ports are already in use on your machine.
HTTP_PORT=8080
HTTPS_PORT=8443
